{%- doc -%}
  Renders the sorting component.

  @param {object} results - The results of the search
  @param {string} sort_by - The current sort by
  @param {string} filter_style - The filter style
  @param {string} [suffix] - { 'desktop' | 'mobile' | 'overflow' } Used on `form` attributes to connect inputs to a form[id]
  @param {string} [sort_position] - { 'desktop' | 'mobile' } Used in a data-testID selector for automated testing
  @param {boolean} should_use_select_on_mobile - Whether to use a select element for the sorting component on mobile
  @param {string} section_id - The section ID
{%- enddoc -%}

<sorting-filter-component
  class="sorting-filter{% if filter_style == 'horizontal' %} sorting-filter__horizontal{% endif %}"
  on:change="/updateFilterAndSorting"
  on:keydown="/handleKeyDown"
  {% if sort_position != blank %}
    data-testid="sorting-filter-component-{{ sort_position }}"
  {% endif %}
  data-should-use-select-on-mobile="{{ should_use_select_on_mobile }}"
>
  {% liquid
    assign default_sort_by = results.default_sort_by
    for option in results.sort_options
      if option.value == sort_by
        assign status = option.name
      endif
    endfor
  %}

  <div class="sorting-filter__container {% if should_use_select_on_mobile %} desktop:hidden {% else %} hidden {% endif %}">
    <label
      for="sort-select-{{ section_id }}"
      class="facets__label"
    >
      {{- 'actions.sort' | t -}}
    </label>
    <div class="sorting-filter__select-wrapper">
      <select
        id="sort-select-{{ section_id }}"
        name="sort_by"
        class="sorting-filter__select"
        {% if should_use_select_on_mobile == false %}
          disabled
        {% endif %}
      >
        {% for option in results.sort_options %}
          <option
            value="{{ option.value }}"
            {% if option.value == sort_by %}
              selected
            {% endif %}
          >
            {{ option.name }}
          </option>
        {% endfor %}
      </select>
      <svg
        aria-hidden="true"
        focusable="false"
        class="icon icon-caret"
        width="8"
        height="13"
        viewBox="0 0 8 13"
      >
        {%- render 'icon', icon: 'double-sided-caret' -%}
      </svg>
    </div>
  </div>

  {% capture accordion_children %}
    <details
      ref="details"
      id="Sorting-{{ section_id }}"
      data-default-sort-by="{{ default_sort_by }}"
      class="facets__panel {% if should_use_select_on_mobile %} mobile:hidden {% endif %}"
      data-auto-close-details="desktop,mobile"
      on:toggle="/handleToggle"
    >
      <summary
        class="facets__summary"
        role="button"
        aria-expanded="false"
        aria-controls="sorting-options-{{ section_id }}-{{ suffix }}"
        ref="summary"
      >
        <span
          class="facets__label"
          id="sort-label-{{ section_id }}"
        >
          {{- 'actions.sort' | t -}}
        </span>
        <span
          class="facets__status h6 desktop:hidden"
        >
          {{- status -}}
        </span>
        <span class="svg-wrapper icon-caret icon-animated">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </summary>
      <floating-panel-component
        id="sorting-options-{{ section_id }}-{{ suffix }}"
        class="sorting-filter__options color-{{ settings.popover_color_scheme }}"
        role="listbox"
        aria-labelledby="sort-label-{{ section_id }}"
        ref="listbox"
      >
        <div class="sorting-filter__options-inner">
          {% for option in results.sort_options %}
            <div
              class="sorting-filter__row"
              data-sort-trigger
              data-sort-value="{{ option.value }}"
              role="option"
              aria-selected="{% if option.value == sort_by %}true{% else %}false{% endif %}"
              tabindex="{% if option.value == sort_by %}0{% else %}-1{% endif %}"
            >
              <input
                type="radio"
                name="sort_by"
                id="sort-option-{{ option.value }}-{{ section_id }}"
                {% if suffix != blank %}
                  form="FacetFiltersForm--{{ section_id }}-{% if suffix == 'mobile' %}mobile-sorting-only{% else %}{{ suffix }}{% endif %}"
                {% endif %}
                value="{{ option.value }}"
                class="sorting-filter__input"
                data-option-name="{{ option.name }}"
                {% if option.value == sort_by %}
                  checked
                {% endif %}
                on:change="/updateFilterAndSorting"
              >
              <span class="svg-wrapper icon-checkmark sorting-filter__checkmark" aria-hidden="true">
                {{- 'icon-checkmark.svg' | inline_asset_content -}}
              </span>
              <span class="sorting-filter__label">{{ option.name }}</span>
            </div>
          {% endfor %}
        </div>
      </floating-panel-component>
    </details>
  {% endcapture %}
  {%- liquid
    assign is_horizontal = false
    if filter_style == 'horizontal'
      assign is_horizontal = true
    endif
  -%}
  {% render 'accordion-custom-component',
    children: accordion_children,
    disable_animation_on_desktop: is_horizontal,
    close_with_escape: is_horizontal
  %}
</sorting-filter-component>

{% stylesheet %}
  .sorting-filter__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-inline: var(--drawer-padding) 0;
    padding-block: var(--padding-sm);
    margin-inline-end: var(--margin-md);
    position: relative;
  }

  .sorting-filter__container .facets__label {
    font-family: var(--kh-display);
    font-weight: 600;
    font-size: var(--font-h4--size);
    letter-spacing: -0.01em;
    color: var(--color-foreground, var(--kh-ink));
  }

  .sorting-filter__select-wrapper {
    display: flex;
    position: relative;
    align-items: center;
    background: var(--kh-white);
    border: 1.5px solid var(--kh-line);
    border-radius: var(--kh-radius-pill, 999px);
    padding: 10px 16px 10px 18px;
    box-shadow: var(--kh-shadow-sm);
    transition: border-color .2s ease, box-shadow .2s ease, transform .2s ease;
    cursor: pointer;
  }

  .sorting-filter__select-wrapper:hover {
    border-color: var(--kh-coral);
    box-shadow: 0 6px 18px -10px rgba(255, 111, 94, .45);
  }

  .sorting-filter__select-wrapper:has(:focus-visible) {
    outline: 2px solid var(--kh-coral);
    outline-offset: 2px;
    border-color: var(--kh-coral);
  }

  .sorting-filter__select-wrapper:has(:focus-visible) .sorting-filter__select {
    outline: none;
  }

  .sorting-filter__container .sorting-filter__select {
    appearance: none;
    border: 0;
    margin: 0;
    cursor: pointer;
    width: 100%;
    padding-inline-end: 22px;
    text-align: right;
    background: transparent;
    color: var(--color-foreground, var(--kh-ink));
    font-family: var(--kh-sans);
    font-size: 14px;
    font-weight: 500;

    /* Needed for Safari */
    text-align-last: right;
  }

  .sorting-filter__select .icon {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    width: 12px;
    height: 12px;
    pointer-events: none;
    color: var(--kh-coral);
  }

  .sorting-filter {
    position: relative;
    z-index: var(--facets-upper-z-index, 3);
  }

  .sorting-filter .facets__panel {
    position: relative;
  }

  /* The summary that opens the dropdown — make it a real button */
  .sorting-filter .facets__summary {
    list-style: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 18px;
    background: var(--kh-white);
    border: 1.5px solid var(--kh-line);
    border-radius: var(--kh-radius-pill, 999px);
    box-shadow: var(--kh-shadow-sm);
    font-family: var(--kh-sans);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-foreground, var(--kh-ink));
    transition: border-color .2s ease, box-shadow .2s ease, transform .2s ease;
    user-select: none;
  }

  .sorting-filter .facets__summary::-webkit-details-marker { display: none; }
  .sorting-filter .facets__summary::marker { display: none; content: ''; }

  .sorting-filter .facets__summary:hover {
    border-color: var(--kh-coral);
    box-shadow: 0 6px 18px -10px rgba(255, 111, 94, .45);
  }

  .sorting-filter .facets__summary:focus-visible {
    outline: 2px solid var(--kh-coral);
    outline-offset: 2px;
  }

  .sorting-filter .facets__summary .facets__label {
    font-family: var(--kh-display);
    font-weight: 600;
    font-size: 14px;
    color: var(--color-foreground, var(--kh-ink));
    letter-spacing: 0.01em;
  }

  .sorting-filter .facets__summary .facets__status.h6 {
    font-weight: 600;
    color: var(--kh-coral-deep);
  }

  .sorting-filter .facets__summary .svg-wrapper.icon-caret.icon-animated {
    color: var(--kh-coral);
    transition: transform .25s ease;
  }

  .sorting-filter details[open] .facets__summary .svg-wrapper.icon-caret.icon-animated {
    transform: rotate(180deg);
  }

  .sorting-filter__options {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    color: var(--color-foreground, var(--kh-ink));
    z-index: var(--facets-upper-z-index, 3);
    background: var(--kh-white);
    border: 1.5px solid var(--kh-line);
    border-radius: var(--kh-radius, 18px);
    box-shadow: var(--kh-shadow-md);
    width: max-content;
    min-width: 240px;
    min-height: 0;
    overflow: hidden;
    transform: translateY(-6px);
    transition: grid-template-rows .25s ease, opacity .2s ease, transform .25s ease;
  }

  details[open] .sorting-filter__options {
    opacity: 1;
    grid-template-rows: 1fr;
    transform: translateY(0);
  }

  .sorting-filter__options-inner {
    display: flex;
    flex-direction: column;
    grid-row: 1 / span 2;
    gap: 2px;
    padding: 8px;
    color: var(--color-foreground, var(--kh-ink));
    overflow: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;

    &::-webkit-scrollbar {
      display: none;
    }

    @media screen and (min-width: 750px) {
      gap: 0;
    }
  }

  .sorting-filter__row {
    cursor: pointer;
    display: grid;
    grid-template-columns: 20px 1fr;
    gap: 10px;
    align-items: center;
    min-width: 0;
    max-width: none;
    width: 100%;
    padding: 10px 12px;
    color: var(--color-foreground, var(--kh-ink));
    font-family: var(--kh-sans);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.3;
    border-radius: var(--kh-radius-sm, 10px);
    user-select: none;
    transition: background-color .15s ease, color .15s ease;
  }

  .sorting-filter__row:hover {
    background: var(--kh-sand-soft, #fbf3e2);
    color: var(--kh-coral-deep);
  }

  .sorting-filter__row:focus-within {
    outline: none;
  }

  .sorting-filter__row:focus-visible {
    background: var(--kh-sand-soft, #fbf3e2);
    outline: 2px solid var(--kh-coral);
    outline-offset: -2px;
  }

  .sorting-filter__input {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    clip: rect(0 0 0 0);
    overflow: hidden;
    white-space: nowrap;
  }

  .sorting-filter__checkmark {
    visibility: hidden;
    display: inline-flex;
    width: 20px;
    height: 20px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--kh-coral);
    color: var(--kh-white);
    flex-shrink: 0;
  }

  .sorting-filter__checkmark svg {
    width: 12px;
    height: 12px;
  }

  .sorting-filter__input:checked ~ .sorting-filter__checkmark {
    visibility: visible;
  }

  .sorting-filter__input:checked ~ .sorting-filter__label {
    color: var(--kh-coral-deep);
    font-weight: 600;
  }

  .sorting-filter__label {
    cursor: pointer;
    pointer-events: none;
    color: inherit;
  }

  .facets-toggle--no-filters .sorting-filter__select-wrapper {
    @media screen and (max-width: 749px) {
      padding-inline-start: 0;
    }
  }

  .facets-mobile-wrapper .sorting-filter .facets__panel {
    padding-inline: 0;
    position: relative;
  }

  .facets-mobile-wrapper .sorting-filter .facets__status {
    display: none;
  }

  .facets-mobile-wrapper:has(> :nth-child(2)) .sorting-filter .sorting-filter__options {
    left: 0;
    right: unset;
  }

  .facets-mobile-wrapper .sorting-filter .facets__label {
    margin-inline-end: var(--margin-2xs);
    font-size: var(--font-paragraph--size);
    color: var(--color-foreground-muted);
  }

  .facets-toggle .sorting-filter__container {
    @media screen and (max-width: 749px) {
      padding: 0;
    }
  }

  .facets-toggle .sorting-filter__container .facets__label {
    @media screen and (max-width: 749px) {
      display: none;
    }
  }

  .facets-toggle .sorting-filter::before {
    @media screen and (max-width: 749px) {
      display: none;
    }
  }

  .facets--drawer .sorting-filter {
    @media screen and (min-width: 750px) {
      display: none;
    }
  }
{% endstylesheet %}
