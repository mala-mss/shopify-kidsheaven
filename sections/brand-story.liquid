{%- comment -%}
  Kid's Haven — Brand story.
  Two-column: image (with floating decorative blob) + text. Reverse option.
{%- endcomment -%}

<section class="kh-story kh-reveal {% if section.settings.reverse %}kh-story--reverse{% endif %}"
         aria-label="{{ section.settings.heading | default: 'Our story' }}">
  <div class="kh-wrap">
    <div class="kh-story__grid">
      <div class="kh-story__media-wrap" data-reveal>
        <span class="kh-story__blob" aria-hidden="true"></span>
        <div class="kh-story__media">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 1200 | image_tag:
              loading: 'lazy',
              widths: '400,600,800,1000,1200',
              sizes: '(min-width: 900px) 50vw, 100vw',
              alt: section.settings.image.alt | default: section.settings.heading
            }}
          {%- else -%}
            <div style="width:100%;height:100%;background:linear-gradient(135deg, var(--kh-sand), var(--kh-coral));"></div>
          {%- endif -%}
        </div>
      </div>
      <div class="kh-story__body" data-reveal data-reveal-delay="1">
        {%- if section.settings.eyebrow != blank -%}
          <span class="kh-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="kh-h2">{{ section.settings.heading }}</h2>
        <div>{{ section.settings.body }}</div>
        {%- if section.settings.cta_label != blank -%}
          <a class="kh-btn kh-btn--coral" href="{{ section.settings.cta_link | default: '#' }}">
            {{ section.settings.cta_label }}
            <span aria-hidden="true">→</span>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "KH Brand story",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "checkbox", "id": "reverse", "label": "Image on right", "default": false },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A beach club for the small ones." },
    { "type": "richtext", "id": "body", "label": "Body",
      "default": "<p>Kid's Haven started in a tiny coastal studio with a simple belief: kids deserve beach clothes that feel as good as they look. We design every piece in-house, source sun-safe and OEKO-TEX certified fabrics, and partner with fair-wage workshops who treat every stitch like it matters — because to a kid, it kind of does.</p><p>The result? Colorful, premium, ready-for-anything pieces built to last more than one summer. Designed by parents, for parents who refuse to compromise on quality (or fun).</p>" },
    { "type": "text", "id": "cta_label", "label": "Button", "default": "Read more" },
    { "type": "url",  "id": "cta_link", "label": "Button link" }
  ],
  "presets": [{ "name": "KH Brand story" }]
}
{% endschema %}
