{%- comment -%}
  Kid's Haven — 404 page.
  Pure branded layout using the KH design tokens.
{%- endcomment -%}

<div class="kh-404-wrap">
  <div class="kh-empty kh-reveal is-in">
    <span class="kh-empty__icon" aria-hidden="true">✦</span>
    <h1 data-reveal>{{ 'kh.not_found.title' | t }}</h1>
    <p data-reveal data-reveal-delay="1">{{ 'kh.not_found.body' | t }}</p>
    <a href="{{ routes.root_url }}" class="kh-btn kh-btn--coral" data-reveal data-reveal-delay="2">
      {{ 'kh.not_found.home' | t }} <span aria-hidden="true">→</span>
    </a>
  </div>
</div>

{% schema %}
{
  "name": "t:names.404",
  "class": "section-wrapper",
  "settings": []
}
{% endschema %}
