{%- if section.settings.message != blank -%}
  <div class="kh-announcement" role="region" aria-label="Announcement">
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}" style="color:inherit;text-decoration:none">
        {{ section.settings.message }}
      </a>
    {%- else -%}
      {{ section.settings.message }}
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "text", "id": "message", "label": "Message", "default": "Livraison offerte dès 5000 DA — Nouvelle collection été" },
    { "type": "url", "id": "link", "label": "Optional link" }
  ],
  "presets": [{ "name": "Announcement bar" }]
}
{% endschema %}
