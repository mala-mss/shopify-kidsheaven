{%- comment -%}
  Kid's Haven — Featured collection (best sellers / new arrivals).
  Uses Horizon's product-card snippet for compatibility, plus KH classes
  for the playful card look defined in kids-haven.css.
{%- endcomment -%}

{%- liquid
  assign collection = collections[section.settings.collection]
  assign limit = section.settings.products_to_show | default: 8
  assign bg = section.settings.background
-%}

<section class="kh-section kh-reveal kh-section--{{ bg }}"
         aria-label="{{ section.settings.heading | default: 'Featured products' }}">
  <div class="kh-wrap">
    <header class="kh-section__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="kh-eyebrow" data-reveal>{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="kh-h2" data-reveal data-reveal-delay="1">{{ section.settings.heading }}</h2>
      <hr class="kh-rule" data-reveal data-reveal-delay="2" style="width:48px;height:3px;background:var(--kh-coral);border:0;border-radius:2px;">
      {%- if section.settings.description != blank -%}
        <p data-reveal data-reveal-delay="3">{{ section.settings.description }}</p>
      {%- endif -%}
    </header>

    <div class="kh-products">
      {%- if collection and collection.products.size > 0 -%}
        {%- for product in collection.products limit: limit -%}
          <a class="kh-card" href="{{ product.url }}" data-reveal data-reveal-delay="{{ forloop.index | modulo: 4 | plus: 1 }}">
            <div class="kh-card__media">
              {%- if product.featured_image != blank -%}
                {{ product.featured_image | image_url: width: 800 | image_tag:
                  loading: 'lazy',
                  widths: '300,500,800,1000',
                  sizes: '(min-width: 1000px) 25vw, (min-width: 700px) 33vw, 50vw',
                  alt: product.featured_image.alt | default: product.title
                }}
              {%- else -%}
                <div style="width:100%;height:100%;background:var(--kh-sand)"></div>
              {%- endif -%}
              {%- if product.compare_at_price > product.price -%}
                <span class="kh-card__badge">Sale</span>
              {%- elsif product.tags contains 'bestseller' or product.tags contains 'best-seller' -%}
                <span class="kh-card__badge" style="background:var(--kh-turquoise);box-shadow:var(--kh-shadow-turq);">Bestseller</span>
              {%- elsif product.tags contains 'new' -%}
                <span class="kh-card__badge" style="background:var(--kh-sunny);color:var(--kh-ink);box-shadow:0 8px 24px -8px rgba(240,180,0,.6);">New</span>
              {%- endif -%}
              <button type="button" class="kh-card__quick" aria-label="Quick add to cart" data-quick-add="{{ product.handle }}">
                Quick add
              </button>
            </div>
            <div class="kh-card__body">
              <h3 class="kh-card__title">{{ product.title }}</h3>
              <div class="kh-card__price">
                {%- if product.compare_at_price > product.price -%}
                  <s>{{ product.compare_at_price | money }}</s>
                  <span class="kh-sale">{{ product.price | money }}</span>
                {%- else -%}
                  {{ product.price | money }}
                {%- endif -%}
              </div>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..limit) -%}
          <a class="kh-card" href="/collections/all" aria-hidden="true" data-reveal data-reveal-delay="{{ forloop.index | modulo: 4 | plus: 1 }}">
            <div class="kh-card__media" style="background:var(--kh-sand)"></div>
            <div class="kh-card__body">
              <h3 class="kh-card__title">Sample product</h3>
              <div class="kh-card__price">{{ 1999 | money }}</div>
            </div>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all and collection != blank -%}
      <div class="kh-products__cta">
        <a class="kh-btn kh-btn--ghost" href="{{ collection.url }}">
          {{ section.settings.view_all_label | default: 'View all' }}
          <span aria-hidden="true">→</span>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "KH Featured collection",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Best sellers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The pieces parents keep re-buying." },
    { "type": "textarea", "id": "description", "label": "Description",
      "default": "Quick-dry, sun-safe, ready for the splash. These are the ones that go everywhere with us." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 4, "max": 12, "step": 1, "default": 8 },
    { "type": "checkbox", "id": "show_view_all", "label": "Show 'View all' button", "default": true },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "Shop the full collection" },
    { "type": "select", "id": "background", "label": "Background",
      "options": [
        { "value": "cream", "label": "Sand/cream" },
        { "value": "turq",  "label": "Turquoise" }
      ],
      "default": "cream"
    }
  ],
  "presets": [{ "name": "KH Featured collection" }]
}
{% endschema %}
