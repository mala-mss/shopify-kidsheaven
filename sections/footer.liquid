{%- comment -%}
  Kid's Haven — Footer.
  Dark ink base with rainbow gradient top stripe, sunny yellow headings,
  coral hover-on-socials. Matches the playful-premium palette.
{%- endcomment -%}

<footer class="kh-footer" role="contentinfo">
  <div class="kh-wrap">
    <div class="kh-footer__grid">
      <div>
        <h3 class="kh-footer__brand">{{ shop.name }}</h3>
        <p class="kh-footer__tagline">{{ section.settings.tagline }}</p>
        <div class="kh-footer__socials">
          {%- if section.settings.facebook != blank -%}
            <a href="{{ section.settings.facebook }}" aria-label="Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12.06A10 10 0 1 0 10.4 22v-7.03H7.9v-2.9h2.5V9.83c0-2.47 1.47-3.83 3.7-3.83 1.07 0 2.2.19 2.2.19v2.42h-1.24c-1.22 0-1.6.76-1.6 1.54v1.85h2.72l-.43 2.9h-2.29V22A10 10 0 0 0 22 12.06Z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.instagram != blank -%}
            <a href="{{ section.settings.instagram }}" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.tiktok != blank -%}
            <a href="{{ section.settings.tiktok }}" aria-label="TikTok">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 3v3.2A5.8 5.8 0 0 0 21 9v3a8.8 8.8 0 0 1-5-1.6V15a6 6 0 1 1-6-6v3a3 3 0 1 0 3 3V3h3Z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.pinterest != blank -%}
            <a href="{{ section.settings.pinterest }}" aria-label="Pinterest">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-3.6 19.3c-.1-.8-.2-2 0-2.9l1.3-5.4s-.3-.7-.3-1.7c0-1.6 1-2.8 2.1-2.8 1 0 1.5.8 1.5 1.7 0 1-.7 2.6-1 4-.3 1.2.6 2.1 1.7 2.1 2.1 0 3.7-2.2 3.7-5.4 0-2.8-2-4.8-4.9-4.8-3.3 0-5.3 2.5-5.3 5.1 0 1 .4 2.1.9 2.7.1.1.1.2.1.3l-.3 1.3c-.1.2-.2.3-.4.2-1.5-.7-2.4-2.9-2.4-4.6 0-3.7 2.7-7.2 7.8-7.2 4.1 0 7.3 2.9 7.3 6.8 0 4.1-2.6 7.4-6.2 7.4-1.2 0-2.3-.6-2.7-1.4l-.7 2.9c-.3 1-1 2.3-1.5 3.1A10 10 0 1 0 12 2Z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.youtube != blank -%}
            <a href="{{ section.settings.youtube }}" aria-label="YouTube">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23 7.2a3 3 0 0 0-2.1-2.1C19 4.5 12 4.5 12 4.5s-7 0-8.9.6A3 3 0 0 0 1 7.2 31 31 0 0 0 .5 12 31 31 0 0 0 1 16.8 3 3 0 0 0 3.1 19c1.9.6 8.9.6 8.9.6s7 0 8.9-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 23.5 12 31 31 0 0 0 23 7.2ZM10 15.5v-7l6 3.5-6 3.5Z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'links' -%}
          <div {{ block.shopify_attributes }}>
            <h4 class="kh-footer__title">{{ block.settings.heading }}</h4>
            <ul class="kh-footer__links">
              {%- for link in block.settings.menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

      <div>
        <h4 class="kh-footer__title">Say hi</h4>
        <p>{{ section.settings.address }}</p>
        {%- if section.settings.email != blank -%}
          <p><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></p>
        {%- endif -%}
      </div>
    </div>

    <div class="kh-footer__bottom">
      <span>© {{ 'now' | date: '%Y' }} {{ shop.name }}. Made for the splash.</span>
      {%- if section.settings.show_payment -%}
        <span>{{ shop.enabled_payment_types | payment_type_svg_tag: class: 'payment-icon' }}</span>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "KH Footer",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline",
      "default": "A beach club for kids — colorful, sun-safe, made to last more than one summer." },
    { "type": "text", "id": "address", "label": "Address", "default": "Coastal studio, CA" },
    { "type": "text", "id": "email",   "label": "Email",   "default": "hello@kidshaven.com" },
    { "type": "url",  "id": "facebook",   "label": "Facebook" },
    { "type": "url",  "id": "instagram", "label": "Instagram" },
    { "type": "url",  "id": "tiktok",    "label": "TikTok" },
    { "type": "url",  "id": "pinterest", "label": "Pinterest" },
    { "type": "url",  "id": "youtube",   "label": "YouTube" },
    { "type": "checkbox", "id": "show_payment", "label": "Show payment icons", "default": true }
  ],
  "blocks": [
    {
      "type": "links",
      "name": "Link list",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    }
  ],
  "presets": [{
    "name": "KH Footer",
    "blocks": [
      { "type": "links", "settings": { "heading": "Shop" } },
      { "type": "links", "settings": { "heading": "Help" } }
    ]
  }]
}
{% endschema %}
