{%- liquid
  assign heading = section.settings.heading
  assign sub = section.settings.subheading
  assign eyebrow = section.settings.eyebrow
  assign img = section.settings.image
-%}

<section class="kh-hero" aria-label="Hero">
  <div class="kh-hero__media">
    {%- if img != blank -%}
      {{ img | image_url: width: 2400 | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        widths: '600,900,1200,1600,2000,2400',
        sizes: '100vw',
        alt: img.alt | default: heading
      }}
    {%- else -%}
      <div style="width:100%;height:100%;background:linear-gradient(135deg,var(--kh-blush),var(--kh-sand))"></div>
    {%- endif -%}
  </div>

  <div class="kh-hero__content">
    {%- if eyebrow != blank -%}
      <div class="kh-eyebrow kh-hero__eyebrow">{{ eyebrow }}</div>
    {%- endif -%}
    <h1 class="kh-h1">{{ heading }}</h1>
    {%- if sub != blank -%}
      <p class="kh-hero__sub">{{ sub }}</p>
    {%- endif -%}
    <div class="kh-hero__cta">
      {%- if section.settings.cta_label != blank -%}
        <a class="kh-btn kh-btn--primary" href="{{ section.settings.cta_link | default: routes.all_products_collection_url }}">
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.cta2_label != blank -%}
        <a class="kh-btn kh-btn--ghost" style="color:var(--kh-warm-white);border-color:var(--kh-warm-white)" href="{{ section.settings.cta2_link }}">
          {{ section.settings.cta2_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Collection Été" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "L'élégance des étés d'enfance." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Des maillots pensés pour la peau délicate de vos enfants — coupes précieuses, tissus anti-UV, finitions soignées à la main." },
    { "type": "text", "id": "cta_label", "label": "Primary button", "default": "Découvrir la collection" },
    { "type": "url", "id": "cta_link", "label": "Primary link" },
    { "type": "text", "id": "cta2_label", "label": "Secondary button" },
    { "type": "url", "id": "cta2_link", "label": "Secondary link" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
