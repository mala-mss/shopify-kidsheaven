            "color": "yellow",
            "icon_svg": "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M6 3h12l2 6-4 2v10H8V11L4 9Z'/></svg>"
