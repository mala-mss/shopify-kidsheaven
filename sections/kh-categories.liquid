{%- comment -%}
  Kid's Haven — "Shop the Vibe" category cards
  4 colorful gradient cards linking to collections. Playful, rounded,
  3D-tilt micro-interaction on hover. Scroll-reveal.
{%- endcomment -%}

<section class="kh-cats kh-reveal" aria-label="{{ 'kh.categories.section_label' | t }}">
  <div class="kh-wrap">
    <header class="kh-cats__head">
      <span class="kh-eyebrow" data-reveal>{{ 'kh.categories.eyebrow' | t }}</span>
      <h2 class="kh-h2" data-reveal data-reveal-delay="1">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="kh-lead" data-reveal data-reveal-delay="2">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </header>

    <div class="kh-cats__grid">
      {%- for block in section.blocks -%}
        <a class="kh-cat kh-cat--{{ block.settings.color }}" href="{{ block.settings.link | default: '/collections/all' }}"
           data-tilt data-reveal data-reveal-delay="{{ forloop.index }}" {{ block.shopify_attributes }}>
          <span class="kh-cat__icon" aria-hidden="true">{{ block.settings.icon_svg }}</span>
          <h3 class="kh-cat__title">{{ block.settings.title }}</h3>
          {%- if block.settings.subtitle != blank -%}
            <p class="kh-cat__sub">{{ block.settings.subtitle }}</p>
          {%- endif -%}
          <span class="kh-cat__arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "KH Categories",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pick their summer mood." },
    { "type": "textarea", "id": "subheading", "label": "Subheading",
      "default": "From the first splash to the last ice cream — every piece is made for the season." }
  ],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Swimwear" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Splashes, pools, salty hair." },
        { "type": "url",  "id": "link",  "label": "Collection link" },
        { "type": "select", "id": "color", "label": "Background",
          "options": [
            { "value": "coral",  "label": "Coral sunset" },
            { "value": "turq",   "label": "Turquoise water" },
            { "value": "yellow", "label": "Sunny yellow" },
            { "value": "sand",   "label": "Sandy beige" }
          ],
          "default": "coral"
        },
        { "type": "html", "id": "icon_svg", "label": "Icon (inline SVG, ~32x32)",
          "default": "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M2 18c2-2 4-2 6 0s4 2 6 0 4-2 6 0'/><path d='M2 22c2-2 4-2 6 0s4 2 6 0 4-2 6 0'/><circle cx='12' cy='7' r='3'/></svg>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "KH Categories",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Swimwear",
            "subtitle": "Splashes, pools, salty hair.",
