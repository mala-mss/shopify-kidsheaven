          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Sun Hats",
            "subtitle": "Shade that looks cute.",
            "color": "turq",
            "icon_svg": "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M3 14a9 9 0 0 1 18 0Z'/><path d='M3 14h18'/><path d='M12 5v9'/></svg>"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Cover-Ups",
